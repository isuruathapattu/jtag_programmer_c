# -------------------------------------------------------------
#  Environment Setup
# -------------------------------------------------------------
RUN_DIR = ${PWD}
export JMSPROGRAM := earth
# -------------------------------------------------------------
# GRID command
# -------------------------------------------------------------
GRID_CMD = nc run -I -Ix -r Taskerlist:i OSREL:RHEL8 RAM/100GB --

# -------------------------------------------------------------
# Tool Variables
# -------------------------------------------------------------

# ------------------------------------------------------
# Run Vivado
# ------------------------------------------------------
run_formality:
	${GRID_CMD} formality

run_vcsg:
	${GRID_CMD} vc_static_shell

run_verdi:
	${GRID_CMD} verdi

# ------------------------------------------------------
# Clean Directory
# ------------------------------------------------------
clean:
	@rm -rf work*
	@rm -rf *.log
	@rm -rf logs/*
	@rm -rf reports/*
	@rm -rf novas*
	@rm -rf *.log.bak*
	@rm -rf session_*

# ------------------------------------------------------
# Print help
# ------------------------------------------------------
help:
	@echo "--------------------------------------------------------------------------------------------------"
	@echo "Targets to run:"
	@echo "	make run_vivado		#" 
	@echo "	make clean              # Remove all work files (logs/reports) and saved sessions."
	@echo "--------------------------------------------------------------------------------------------------"

